						"exec": [
							"// Test 1: Verify that the request method is POST\r",
							"pm.test(\"Request method is POST\", function () {\r",
							"    pm.expect(pm.request.method).to.equal(\"POST\");\r",
							"});\r",
							"\r",
							"// Test 2: Verify that the request has the search_product parameter in the body\r",
							"pm.test(\"Request body contains search_product parameter\", function () {\r",
							"    const requestBody = pm.request.body;\r",
							"    \r",
							"    // Check if body mode is formdata\r",
							"    if (requestBody && requestBody.mode === 'formdata') {\r",
							"        const formData = requestBody.formdata;\r",
							"        const searchProductParam = formData.find(param => param.key === 'search_product');\r",
							"        pm.expect(searchProductParam).to.not.be.undefined;\r",
							"        pm.expect(searchProductParam.key).to.equal('search_product');\r",
							"    } else {\r",
							"        pm.expect.fail(\"Request body is not in formdata mode\");\r",
							"    }\r",
							"});\r",
							"\r",
							"// Test 3: Verify that the status code is 200\r",
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"// Test 4: Verify that the response contains valid JSON\r",
							"pm.test(\"Response is valid JSON\", function () {\r",
							"    pm.response.to.be.json;\r",
							"    pm.expect(function() {\r",
							"        pm.response.json();\r",
							"    }).to.not.throw();\r",
							"});\r",
							"\r",
							"// Test 5: Verify that the response contains a products property that is an array\r",
							"pm.test(\"Response contains products array\", function () {\r",
							"    const jsonData = pm.response.json();\r",
							"    pm.expect(jsonData).to.have.property('products');\r",
							"    pm.expect(jsonData.products).to.be.an('array');\r",
							"});\r",
							"\r",
							""
